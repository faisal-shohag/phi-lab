// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

model User {
  id                String             @id
  name              String
  email             String
  emailVerified     Boolean            @default(false)
  image             String?
  xp                Int                @default(0)
  // Helpdesk role. Mentors/admins are seeded lazily from HIVE_MENTOR_EMAILS
  // (see src/lib/hive/roles.ts). STUDENT for everyone else.
  role              Role               @default(STUDENT)
  // Optional career/profile info — surfaced on /profile and the public /u/[id]
  // page. Everything here is opt-in; empty values simply lower the profile
  // completion score. `profilePublic` gates whether /u/[id] is viewable.
  headline          String?
  bio               String?
  goal              String?
  skills            String[]           @default([])
  location          String?
  resumeUrl         String?
  githubUrl         String?
  linkedinUrl       String?
  websiteUrl        String?
  profilePublic     Boolean            @default(false)
  // Suspension. Enforced at DB-read choke points (getHiveUser + the lab token
  // routes), never from the session cookie: better-auth caches the session in a
  // signed JWT for 30 days, so a cookie-only check would let a suspended user
  // keep working until it refreshed.
  suspendedAt       DateTime?
  suspendedReason   String?
  suspendedById     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  interviews        InterviewSession[]
  feynman           FeynmanSession[]
  english           EnglishSession[]
  analogies         AnalogyCard[]
  support           SupportSession[]
  xpEvents          XpEvent[]
  badges            UserBadge[]
  pixelSubmissions  PixelSubmission[]
  challengeAttempts ChallengeAttempt[]
  hivePosts         HivePost[]         @relation("PostAuthor")
  assignedHivePosts HivePost[]         @relation("PostMentor")
  hiveReplies       HiveReply[]
  hiveReactions     HiveReaction[]
  hiveFollows       HiveFollow[]
  hiveNotifications HiveNotification[]
  pathProgress      PathProgress[]
  dailyQuests       DailyQuest[]
  weeklyPlans       WeeklyPlan[]
  quizSessions      QuizSession[]
  codeSubmissions   CodeSubmission[]
  contests          Contest[]          @relation("ContestAuthor")

  @@unique([email])
  @@index([suspendedAt])
  @@map("user")
}

// A staked JS Motion coding challenge. The tests + expected outputs live ONLY
// here (server-side) so a submission is graded against hidden inputs the learner
// never sees. Mutable per-round state (attemptsUsed, status, expiresAt) is why
// this can't just be an append-only XpEvent.
model ChallengeAttempt {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  difficulty        String // easy | medium | hard
  mode              String // oneshot | retries | timed
  lang              String    @default("bengali") // bengali | english (prompt + hint language)
  stake             Int
  status            String    @default("active") // active | won | lost
  fnName            String
  prompt            String // Bengali task text (shown to the learner)
  sampleInput       Json // one visible example input (shown)
  sampleOutput      String // its output (shown)
  tests             Json // SERVER-ONLY: [{ args: [...], expected: string }]
  referenceSolution String? // SERVER-ONLY until won; then revealed to the winner
  attemptsUsed      Int       @default(0)
  maxAttempts       Int // oneshot=1, timed=3, retries=9999
  hintsUsed         Int       @default(0)
  expiresAt         DateTime? // timed mode only
  wonXp             Int? // XP credited on win (base × streak multiplier)
  winStreak         Int? // consecutive-win streak at the moment of this win
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, status])
  @@map("challenge_attempt")
}

// ── Code Lab: LeetCode-style problem solving ───────────────────────────────
// Curated JS/TS problems. Like ChallengeAttempt and QuizSession, the graded
// contract (`tests`, `solutionJs`) is SERVER-ONLY: the API strips hidden cases
// and the reference solution on the way out, and re-grades every submit in a
// QuickJS sandbox on the way in (src/lib/code-lab/grade-qjs.ts). "Run" in the
// browser worker is a convenience preview against visible cases only; XP is
// paid strictly on the server verdict.
enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
  EXTRA_HARD
}

enum ProblemType {
  // Tests call fnName(...args) and deep-compare the return value.
  FUNCTION_RETURN
  // Tests compare captured console.log output. When fnName is null the whole
  // script runs once per case; otherwise fnName(...args) is called first.
  CONSOLE_OUTPUT
}

enum CodeLanguage {
  JAVASCRIPT
  TYPESCRIPT
}

enum SubmissionVerdict {
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT
  // The TS submission failed to transpile server-side.
  COMPILE_ERROR
}

model Problem {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  difficulty  ProblemDifficulty
  type        ProblemType
  description String // markdown
  constraints String[]          @default([])
  hints       String[]          @default([])
  tags        String[]          @default([])
  // Entry point. Null only for program-style CONSOLE_OUTPUT problems.
  fnName      String?
  // Which languages a learner may solve this in. Set at authoring time.
  languages   CodeLanguage[]    @default([JAVASCRIPT, TYPESCRIPT])
  starterJs   String
  starterTs   String
  // SERVER-ONLY reference solution (JS). Validates tests at authoring time and
  // is shown to admins only — never to learners.
  solutionJs  String
  // SERVER-ONLY: { cases: [{ id, hidden, args?, expected?, expectedStdout? }] }.
  // See src/lib/code-lab/types.ts for the exact shape.
  tests       Json
  // First-accept XP award; defaulted from difficulty at create, editable.
  xp          Int
  published   Boolean           @default(false)
  order       Int               @default(0)
  // Admin author. No FK so the problem outlives the account (like AdminSetting).
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  submissions CodeSubmission[]
  // Set when this problem is part of a contest (1:1). While that contest hasn't
  // finished the problem is hidden from the main list.
  contestProblem ContestProblem?

  @@index([published, order])
  @@index([published, difficulty])
  @@map("problem")
}

// Every graded submit, with the code that produced it. Same rationale as
// PixelSubmission: the XpEvent ledger only records the FIRST accept, so it can't
// answer "what did I try". Not a source of truth for XP/solved — those derive
// from XpEvent (award reason "code_lab_solved") and this table can be pruned.
model CodeSubmission {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem           @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language    CodeLanguage
  code        String
  verdict     SubmissionVerdict
  passedCount Int
  totalCount  Int
  // Per-VISIBLE-case results (CaseResult[]) captured at grade time, so the
  // submissions view can replay this run's actual input/output. Hidden cases are
  // never stored here. Null on old rows / compile errors.
  results     Json?
  // Wall clock of the grading run.
  runtimeMs   Int?
  // First runtime/compile error message, truncated. Null on a clean run.
  error       String?
  // Set when this submit was made inside a running contest. Contest scoring
  // derives from these rows. SetNull so pruning a contest keeps the attempt.
  contestId   String?
  contest     Contest?          @relation(fields: [contestId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())

  @@index([userId, problemId, createdAt])
  @@index([userId, verdict, createdAt])
  @@index([problemId, verdict])
  @@index([contestId, verdict])
  @@map("code_submission")
}

// A timed programming contest. Status (upcoming/running/finished) is derived
// from now vs startsAt/endsAt — never stored. Problems attached via
// ContestProblem are hidden from the main Code Lab list until endsAt passes.
model Contest {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String // markdown
  // Displayed author (a MENTOR/ADMIN). FK so we can show name/avatar.
  authorId    String
  author      User             @relation("ContestAuthor", fields: [authorId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  // Draft contests are hidden from learners entirely.
  published   Boolean          @default(false)
  // Admin who built it. No FK — mirrors Problem.createdById.
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  problems    ContestProblem[]
  submissions CodeSubmission[]

  @@index([published, startsAt])
  @@index([published, endsAt])
  @@map("contest")
}

// Join between a contest and a problem, carrying the contest-specific points and
// display order. problemId is unique: a problem belongs to at most one contest.
model ContestProblem {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId String  @unique
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  // Contest score awarded for solving this problem.
  points    Int
  order     Int     @default(0)

  @@unique([contestId, problemId])
  @@index([contestId, order])
  @@map("contest_problem")
}

// Append-only ledger of every XP grant. `reason` + `sourceId` are unique per
// user so awards are idempotent (retrying the same interview/quiz step never
// double-counts). `meta` carries the score/streak used for badge evaluation.
model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  sourceId  String
  meta      Json?
  createdAt DateTime @default(now())

  @@unique([userId, reason, sourceId])
  @@index([userId, createdAt])
  @@map("xp_event")
}

// Every scored Pixel Lab attempt, with the code that produced it.
//
// Why this exists when progress already derives from XpEvent: the ledger is
// idempotent, so it only ever records the *first* time a tier was earned. It
// cannot answer "what have I tried, and did it get better" — a re-score that
// improves 46% to 92% writes nothing at all. This is the attempt log, not the
// receipt: append-only, one row per submit, keeping the html/css so a learner
// can read back what they actually wrote.
//
// Not a source of truth for XP or unlocks. Those stay derived from XpEvent, so
// this table can be pruned or lost without anyone losing progress.
model PixelSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  html        String
  css         String
  // 0…1, the union-based score that pays XP (src/lib/pixel/score.ts).
  score       Float
  // 0…1, the raw pixel match. Kept beside `score` because they answer different
  // questions and the panel shows both.
  match       Float
  diffPixels  Int
  unionPixels Int
  // Tiers this attempt cleared, e.g. ["standing","close"]. What it *earned* is a
  // question for the ledger — a re-score clears tiers it was already paid for.
  tiers       String[] @default([])
  createdAt   DateTime @default(now())

  @@index([userId, challengeId, createdAt])
  @@map("pixel_submission")
}

// Unlocked achievements. Badge definitions live in code
// (src/lib/gamification/badges.ts); this only records which user has which.
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badge")
}

/**
 * Shared by the interview, feynman and english labs — they run the same lifecycle.
 */
enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  /**
   * The learner walked away — closed the tab or navigated off mid-round. Without
   * this, such a session sits at IN_PROGRESS forever: it never reaches a report,
   * so nothing ever moves it on. Set by /api/labs/abandon on unload, and by the
   * cron sweep for the beacon that never arrived.
   */
  ABANDONED
}

model InterviewSession {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic        String
  level        String
  language     String          @default("en")
  voice        String          @default("Kore")
  includeIntro Boolean         @default(false)
  pressure     String          @default("neutral")
  status       InterviewStatus @default(IN_PROGRESS)
  transcript   Json?
  report       Json?
  overallScore Int?
  startedAt    DateTime        @default(now())
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([userId, topic])
  @@map("interview_session")
}

// Feynman ("teach-back") lab: the learner explains a concept aloud to an AI
// that plays a curious beginner. Mirrors InterviewSession but stores a clarity
// score and a teach-back report instead of an interview score.
model FeynmanSession {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept      String
  language     String          @default("en")
  voice        String          @default("Kore")
  status       InterviewStatus @default(IN_PROGRESS)
  transcript   Json?
  report       Json?
  clarityScore Int?
  startedAt    DateTime        @default(now())
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId, createdAt])
  @@map("feynman_session")
}

// English-for-Developers lab: spoken technical-English practice. The AI plays a
// role (interviewer, manager, teammate) in a chosen scenario; the report grades
// the learner's spoken English (fluency, clarity, confidence) with concrete
// grammar/vocabulary fixes.
model EnglishSession {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario     String
  voice        String          @default("Kore")
  status       InterviewStatus @default(IN_PROGRESS)
  transcript   Json?
  report       Json?
  overallScore Int?
  startedAt    DateTime        @default(now())
  endedAt      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId, createdAt])
  @@map("english_session")
}

// Rickshaw Analogies: an AI-generated everyday analogy for a concept, rendered
// as a shareable card. Cards are readable by anyone with the link (public share
// pages); only the owner can create/delete.
model AnalogyCard {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept     String
  language    String   @default("en")
  title       String
  scene       String
  mapping     Json
  soBasically String
  techNote    String
  emoji       String   @default("🛺")
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@map("analogy_card")
}

// Support Session lab: a live voice call with an AI supporter about anything —
// a coding problem, mental support, or learning guidance. Capped at 3 ACTIVE
// sessions platform-wide; everyone else waits in a FIFO queue. No AI report is
// generated — the learner rates the session (1-5) afterwards instead.
//   status: waiting  -> in the queue, not yet connected
//           active   -> holding one of the 3 live slots (heartbeat via lastSeenAt)
//           completed-> finished (10-min cap or ended early)
//           abandoned-> left the queue / tab died before connecting
model SupportSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String // 'coding' | 'mental' | 'guidance' | 'other'
  problem    String // written before joining; seeds the AI's context
  language   String    @default("en") // 'en' | 'bn'
  voice      String    @default("Kore")
  status     String    @default("waiting")
  transcript Json?
  rating     Int? // 1-5, set after the session
  feedback   String? // optional free-text comment
  lastSeenAt DateTime  @default(now()) // heartbeat; a stale active row frees its slot
  startedAt  DateTime? // set when promoted to active
  endedAt    DateTime?
  createdAt  DateTime  @default(now()) // FIFO queue order
  updatedAt  DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("support_session")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Hive: AI-powered helpdesk ──────────────────────────────────────────────
// A social feed of student problems. The AI answers first (up to 3 attempts);
// unresolved posts escalate to a human mentor. Questions auto-delete after 3
// days unless resolved+accepted, in which case they archive into the Honeycomb
// knowledge base. Announcements and AI encouragement share the same feed via
// `type`. See client/.claude/plans for the full design.

enum HivePostType {
  QUESTION
  ANNOUNCEMENT
  ENCOURAGEMENT
}

enum HivePostStatus {
  OPEN
  AI_WORKING
  ESCALATED
  RESOLVED
  ARCHIVED
}

model HivePost {
  id                      String          @id @default(cuid())
  authorId                String? // null for AI-authored (encouragement) posts
  author                  User?           @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  type                    HivePostType    @default(QUESTION)
  title                   String
  body                    String // markdown
  images                  String[]        @default([]) // cloudinary secure_urls
  tags                    String[]        @default([]) // from triage
  topic                   String? // triage: e.g. "javascript", "css"
  milestone               String? // triage: course milestone guess
  severity                String? // 'low' | 'medium' | 'high'
  sensitive               Boolean         @default(false)
  status                  HivePostStatus  @default(OPEN)
  aiAttemptCount          Int             @default(0) // 0..3
  assignedMentorId        String?
  assignedMentor          User?           @relation("PostMentor", fields: [assignedMentorId], references: [id], onDelete: SetNull)
  acceptedReplyId         String?         @unique // plain unique string, no FK (avoids circular relation)
  pinned                  Boolean         @default(false) // announcements
  // Set on AI-authored posts (ENCOURAGEMENT). Staff-only, like HiveReply.aiProvider.
  aiProvider              AiProvider?
  kbSummary               String? // AI-distilled summary written at archive time
  expiresAt               DateTime // createdAt + 3 days (questions); far future for announcements
  resolvedAt              DateTime?
  archivedAt              DateTime?
  // Denormalized outcome, written at the terminal transitions. Derivable from
  // events + replies, but the admin dashboard slices on these constantly and a
  // three-table join per tile is not worth it.
  resolvedBy              HiveResolver? // who wrote the accepted answer
  escalatedAt             DateTime?
  escalationReason        String?
  // AI answers posted before the hand-off. 0 = the AI never got to try
  // (sensitive topic, "need a human", or every provider failed on attempt 1).
  escalatedAfterAiReplies Int?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  // Full-text search is served by a GIN *expression* index over
  // to_tsvector(title||body||kbSummary) — see prisma/sql/hive_fts.sql. It adds
  // no column, so `prisma db push` stays drift-free; queries in
  // src/lib/hive/search.ts repeat the same expression so the index is used.
  replies                 HiveReply[]
  events                  HivePostEvent[]
  reactions               HiveReaction[]
  follows                 HiveFollow[]

  @@index([status, pinned, createdAt])
  @@index([expiresAt, status])
  @@index([authorId, createdAt])
  @@index([assignedMentorId, status])
  @@map("hive_post")
}

/**
 * Who actually solved it — the headline number for "did the AI carry its weight".
 */
enum HiveResolver {
  AI
  PEER
  MENTOR
}

enum HiveAuthorType {
  STUDENT
  MENTOR
  AI
}

enum HiveReplyKind {
  ANSWER
  CLARIFYING_QUESTION
  COMMENT
}

enum HiveVerification {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model HiveReply {
  id           String           @id @default(cuid())
  postId       String
  post         HivePost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorType   HiveAuthorType
  authorId     String? // null when authorType == AI
  author       User?            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind         HiveReplyKind    @default(COMMENT)
  body         String // markdown
  images       String[]         @default([])
  aiAttempt    Int? // 1|2|3 on AI answers — this IS the attempt log
  // Which model wrote this. Never sent to students: they see "Hive AI", one
  // consistent identity. Only mentors/admins see the provider behind it.
  aiProvider   AiProvider?
  stillStuck   Boolean          @default(false) // student pressed "still stuck" with this reply
  verification HiveVerification @default(NONE) // Bee-Approved pipeline for peer ANSWERs
  verifyNote   String? // AI's one-line verdict note
  createdAt    DateTime         @default(now())
  reactions    HiveReaction[]

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@map("hive_reply")
}

// Append-only status timeline (audit spirit): created, triaged, ai_attempt_1..3,
// escalated, mentor_assigned, resolved, archived.
model HivePostEvent {
  id        String   @id @default(cuid())
  postId    String
  post      HivePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@map("hive_post_event")
}

// Nectar reactions. targetKey = "post:<id>" | "reply:<id>" makes the unique
// constraint work despite nullable FKs (PG treats NULLs as distinct in uniques).
model HiveReaction {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      HivePost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId   String?
  reply     HiveReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  targetKey String
  createdAt DateTime   @default(now())

  @@unique([userId, targetKey])
  @@index([replyId])
  @@index([postId])
  @@map("hive_reaction")
}

model HiveFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      HivePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("hive_follow")
}

// ── The Path: guided curriculum ───────────────────────────────────────────
// The curriculum itself (modules, nodes, the steps each node demands) lives in
// code — src/lib/path/curriculum.ts — for the same reason badge definitions do:
// shipping a new node should be a code change, not a migration + seed.
//
// Step *completion* is likewise not stored. It is derived on read from evidence
// that already exists: XpEvents (viz concepts), ChallengeAttempt wins, and the
// per-lab session tables. That keeps a single source of truth — a node cannot
// claim you mastered something the labs never recorded.
//
// Only the three things that cannot be derived are persisted below: the moment
// a node was *mastered* (needed for idempotent XP + an honest transcript), the
// daily quest (a composed-once, stable list — recomposing it mid-day would move
// the goalposts), and the AI's weekly plan (an expensive generation, cached).

/**
 * Terminal only. LOCKED/AVAILABLE/ACTIVE are derived from prerequisites.
 */
model PathProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeId     String
  /**
   * Snapshot of the evidence that satisfied each step — the "receipt".
   */
  evidence   Json?
  masteredAt DateTime @default(now())

  @@unique([userId, nodeId])
  @@index([userId, masteredAt])
  @@map("path_progress")
}

// One composed quest per learner per UTC day. `items` is the frozen list of
// step references; whether each is *done* is re-derived from the same evidence
// the path uses, so a quest item cannot be marked complete without the lab
// actually recording the work.
model DailyQuest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * UTC calendar day, "YYYY-MM-DD". Also the idempotency key for the XP grant.
   */
  day         String
  items       Json
  /**
   * Set the first time every item is satisfied. Drives the streak.
   */
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, day])
  @@index([userId, day])
  @@map("daily_quest")
}

// The AI's weekly re-plan + report card. One per learner per ISO week, cached:
// this is the only recurring AI cost the path carries, so it must not be
// regenerated on every page view.
model WeeklyPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * Monday of the ISO week, "YYYY-MM-DD".
   */
  weekOf    String
  /**
   * Node ids the AI wants the learner to focus on this week.
   */
  focus     String[] @default([])
  /**
   * The full structured report (wins, struggles, encouragement, bn + en).
   */
  report    Json
  createdAt DateTime @default(now())

  @@unique([userId, weekOf])
  @@index([userId, createdAt])
  @@map("weekly_plan")
}

// ── The Quiz Lab ──────────────────────────────────────────────────────────
// AI-generated quizzes on chosen topics. One row per generated quiz. Owned by
// the Quiz Lab feature (feature/quiz-lab); this schema mirrors that DB shape.
model QuizSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics        String[]
  difficulty    String   @default("beginner")
  questionCount Int      @default(10)
  /** SERVER-ONLY question set (with answers), stripped before sending to client. */
  questions     Json     @default("[]")
  /** Learner's chosen option index per item, set on submit. */
  answers       Json?
  /** 0-100, set on submit. */
  score         Int?
  total         Int      @default(0)
  xpAwarded     Int      @default(0)
  status        String   @default("in_progress")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("quiz_session")
}

// ── AI telemetry ──────────────────────────────────────────────────────────
// One row per call to an AI provider — successes and failures alike. Append-only,
// like XpEvent. This is the source of truth for the admin dashboard: who was
// used, how often, how fast, how many tokens, and why a call failed.
//
// postId is deliberately NOT a foreign key: questions are hard-deleted after 3
// days, and usage history must outlive them. The same reason HiveNotification
// keeps a bare postId.

enum AiProvider {
  GEMINI
  OLLAMA
  GROQ
}

/**
 * Which product surface the call was made for. Orthogonal to AiTask: `feature`
 * is *where* the work happened, `task` is *what job* the model did. Folding the
 * labs into AiTask would make groupBy(['task']) mix Hive's TRIAGE with an
 * interview round.
 */
enum AiFeature {
  HIVE
  INTERVIEW
  FEYNMAN
  ENGLISH
  SUPPORT
  ANALOGIES
  JS_MOTION
  /**
   * The Path: weekly re-plan + report card.
   */
  PATH
  /**
   * The Quiz Lab: AI-generated topic quizzes.
   */
  QUIZ
  /**
   * Code Lab: AI-assisted problem authoring (description + starters + tests).
   */
  CODE_LAB
}

/**
 * Which job the model was doing. Cost and failure rates differ wildly per task.
 */
enum AiTask {
  TRIAGE
  ANSWER
  VERIFY
  COACH
  KB_SUMMARY
  ENCOURAGEMENT
  /**
   * A live voice round. Tokens are client-reported — see tokensClientReported.
   */
  LIVE_SESSION
  /**
   * Post-session grading via a one-shot structured generateContent.
   */
  REPORT
  /**
   * Analogies: one-shot card generation.
   */
  GENERATE
  /**
   * JS Motion: explain a step or an error to the learner.
   */
  EXPLAIN
  /**
   * The Path: re-plan the coming week and write the report card.
   */
  PLAN
  /**
   * The Quiz Lab: generate a topic quiz.
   */
  GENERATE_QUIZ
}

/**
 * Coarse bucket for dashboards; `errorMessage` keeps the detail.
 */
enum AiErrorKind {
  RATE_LIMITED
  AUTH
  BAD_REQUEST
  TIMEOUT
  TRUNCATED
  INVALID_JSON
  SERVER_ERROR
  NO_PROVIDER
  UNKNOWN
}

model AiUsageEvent {
  id        String     @id @default(cuid())
  feature   AiFeature  @default(HIVE) // the default backfills every pre-existing row correctly
  provider  AiProvider
  /**
   * Which API key served the call, identified by its ENV VAR NAME
   * ("GEMINI_API_KEY_1"), never its value. Null on rows written before keys were
   * rotated, and on NO_PROVIDER rows where no key was ever reached.
   */
  keyId     String?
  model     String
  task      AiTask
  success   Boolean
  /**
   * 1..3 for ANSWER; null for one-shot tasks.
   */
  aiAttempt Int?
  /**
   * Position in the failover chain for this call: 1 = first provider tried.
   */
  tryIndex  Int        @default(1)

  latencyMs            Int
  /**
   * Wall clock of a live voice round. Distinct from latencyMs, which is one call.
   */
  durationMs           Int?
  promptTokens         Int?
  responseTokens       Int?
  totalTokens          Int?
  /**
   * True when the browser reported the counts (live rounds). Treat as untrusted.
   */
  tokensClientReported Boolean @default(false)
  /**
   * The model's self-reported confidence on ANSWER calls.
   */
  confidence           Int?

  errorKind    AiErrorKind?
  errorMessage String?

  postId    String? // no FK — usage history outlives the post
  userId    String? // the student the work was for; null for cron-authored posts
  sessionId String? // the lab session this belongs to; null for Hive

  createdAt DateTime @default(now())

  // Idempotency for the client-reported live flush is a PARTIAL unique index,
  // added by raw SQL in the migration (Prisma cannot express it):
  //   CREATE UNIQUE INDEX ai_usage_live_once ON ai_usage_event (feature, session_id)
  //     WHERE task = 'LIVE_SESSION' AND session_id IS NOT NULL;
  // A plain @@unique([feature, sessionId]) would collide — interview writes both
  // a LIVE_SESSION and a REPORT row for one session. And @@unique([feature, task,
  // sessionId]) would block logging a failed report followed by a successful
  // retry, which is exactly the failure data this table exists to show.

  @@index([createdAt])
  @@index([provider, createdAt])
  @@index([task, success, createdAt])
  @@index([success, errorKind, createdAt])
  @@index([feature, createdAt])
  @@index([feature, task, provider, createdAt])
  @@index([keyId, task, createdAt])
  @@map("ai_usage_event")
}

// Last-observed rate-limit health per API KEY, one row each. The live health lives
// in an in-memory Map in src/lib/ai-keys/pool.ts, which is per-serverless-instance:
// the admin dashboard runs in an instance that never made an AI call, so it can't
// read that Map. This table is the durable, cross-instance mirror the dashboard
// reads. Written best-effort from park()/recordRateLimit(); never on the hot path's
// critical section.
//
// The PK is the key's ENV VAR NAME, never its value — safe to log, store and show.
// Keys are discovered from the environment by convention, so rows appear on their
// own the first time a newly added key is used; a key removed from the env leaves a
// stale row behind, which the dashboard drops because it merges against the pool.
model ApiKeyHealth {
  keyId         String     @id
  provider      AiProvider
  /**
   * Requests left in the current window. Groq only — Gemini/Ollama send no header.
   */
  remaining     Int?
  /**
   * When the parked key frees up. Read side computes remaining ms from this.
   */
  cooldownUntil DateTime?
  /**
   * Per-key kill switch. The provider-level switches are AdminSettings, but keys
   * are dynamic — there is no static settings key to name one — so a key's switch
   * lives on its own row.
   */
  adminParked   Boolean    @default(false)
  lastError     String?
  updatedAt     DateTime   @updatedAt

  @@map("api_key_health")
}

// Which API key minted the ephemeral token for a live voice round.
//
// A live round runs browser <-> Google directly, and the browser reports its token
// usage back to /api/ai-usage/live afterwards. The browser must NOT be told which
// key it is on — client-reported telemetry would then let a user poison another
// key's stats — so the token route records the link here and the usage endpoint
// joins on sessionId to stamp the row. No FK: the session tables are per-lab, and
// usage history outlives them.
model LiveTokenIssue {
  sessionId String    @id
  feature   AiFeature
  keyId     String
  model     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("live_token_issue")
}

// type: 'reply' | 'bee_approved' | 'accepted' | 'escalated' | 'mentor_assigned'
//     | 'announcement' | 'badge'. postId has NO FK so bell history survives the
// 3-day post auto-deletion.
model HiveNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  postId    String?
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@map("hive_notification")
}

// ── Admin ─────────────────────────────────────────────────────────────────
// Key/JSON rather than a column per knob: the settings are heterogeneous and
// keep growing (round time per lab, daily limit per lab, kill switch per lab,
// park switch per provider). A column-per-knob table forces a migration for
// every new toggle. Defaults and validation live in code
// (src/lib/admin/settings-defaults.ts), so an empty table behaves as before.

model AdminSetting {
  key       String   @id // e.g. "lab.interview.roundSeconds"
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String? // admin user id; no FK so the trail outlives the account

  @@map("admin_setting")
}

/// Append-only. Role escalation with no trail is how platforms get owned.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String // the admin who did it
  action     String // "user.role.set" | "user.suspend" | "setting.update" | ...
  targetType String? // "user" | "setting" | "provider"
  targetId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@map("admin_audit_log")
}
